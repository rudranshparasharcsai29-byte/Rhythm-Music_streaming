{
  "name": "rhythm-backend",
  "version": "1.0.0",
  "description": "Production-ready music streaming backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "setup": "node setup.js && npm install",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "music",
    "streaming",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "youtubei.js": "^17.0.1",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "prettier": "^3.3.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
